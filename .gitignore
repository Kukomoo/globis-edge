# ─────────────────────────────────────────────────────────────────────────────
# Globis Edge — .gitignore
# Belt-and-braces: explicit excludes for everything that could leak secrets,
# bloat history, or pollute diffs. If you add a new secret-bearing file
# pattern, list it here BEFORE the file is created.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets ──────────────────────────────────────────────────────────────────
# .env carries CASEWORKER_PIN, SALT_HEX, DEVICE_ID and (in deployment) any
# API keys. It must never enter version control.
.env
.env.*
!.env.example

# ── Encrypted databases ──────────────────────────────────────────────────────
# .db files are SQLCipher-encrypted, but committing them would still leak the
# schema's row counts, timing, and structural metadata across history.
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ── Python build / cache ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
*.egg-info/
build/
dist/
wheels/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── OS turds ─────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.codex/
.continue/
*.swp
*.swo
*~

# ── Gemma4 Cloud local settings (per-machine) ───────────────────────────────
# Gemma4 Cloud local-only settings are never tracked.
.claude/settings.local.json

# ── Generated artefacts ──────────────────────────────────────────────────────
# Model weights, audio fixtures, eval outputs that get regenerated from code.
# Do NOT commit GGUF files — they belong on the Pi, not in history.
*.gguf
*.onnx
*.pt
*.bin
eval/reports/
synthetic_cases/**/*.wav
synthetic_cases/**/*.jpg
synthetic_cases/**/*.jpeg
synthetic_cases/**/*.png
!synthetic_cases/**/manifest.json
!synthetic_cases/**/*.transcript.txt
!synthetic_cases/**/caseworker_note.txt

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
.claude/
Gemma4 ai model/

# ── Process / working docs (internal sprint notes, not for judges) ────────────
PRIORITY_*.md
UI_*.md
UI_*.txt
CLEANUP_*.md
CLEANUP_*.txt
CASEWORKER_CONSOLE_*.md
DELIVERY_CHECKLIST.md
HACKATHON_SUBMISSION_ANALYSIS.md
MANIFEST.txt
README_PRIORITY_1.md
START_HERE.md
SUBMISSION_READINESS.txt
SUBMISSION_SUMMARY.md
LANDING_PAGE_INTEGRATION_GUIDE.md
FINAL_SUBMISSION_STATUS.md
SUBMISSION_CHECKLIST.md
cleanup.sh

# ── Development notebook variants (keep only canonical .ipynb in repo) ────────
globis-edge-FIXED*.ipynb
*-v2.ipynb
*-v3.ipynb
*-draft.ipynb
*-working.ipynb

# ── Hidden guides and internal Claude notes (prefixed with dot) ────────────────
.*.md
.*GUIDE.md
.*ANALYSIS.md
.*NOTES.md
CLAUDE.md
INVARIANTS.md
FINAL_AUDIT.md
PRD_FINAL.md
PRD_v9.0_Globis_Edge.md
PRD_v8.0_Globis_Edge.md
FINAL_CLEANUP.sh
COPY_AND_PASTE.txt
YOUR_NEXT_STEPS.md
EXECUTION_SUMMARY.md
READ_ME_FIRST.md
CLEANUP_STATUS.md
TERMINAL_INSTRUCTIONS.txt

# ── Sample dossier test fixtures ──────────────────────────────────────────────
sample-dossier-*.json

# ── Archive (old PRD versions, deprecated docs) ──────────────────────────────
archive/

# ── Vite / React dev artifacts ────────────────────────────────────────────────
globis-edge-ui/node_modules/
globis-edge-ui/dist/
globis-edge-ui/src/App.css
globis-edge-ui/src/assets/react.svg
globis-edge-ui/src/assets/vite.svg
# Dead/superseded component files (kept locally, not for judges)
globis-edge-ui/src/components/Layout/MainLayout.tsx
globis-edge-ui/src/components/Layout/Topbar.tsx
globis-edge-ui/src/components/Screens/Screen1_NewIntake.tsx
globis-edge-ui/src/components/Screens/Screen3_Synthesise.tsx
globis-edge-ui/src/components/Screens/Screen3_Synthesise_Enhanced.tsx
globis-edge-ui/src/components/Screens/Screen4_Explainer.tsx
globis-edge-ui/.gitignore
globis-edge-ui/README.md
